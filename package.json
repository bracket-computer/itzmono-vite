{
  "name": "itzmono-vite",
  "version": "0.0.0",
  "scripts": {
    "dev:vite": "vp dev --host",
    "dev": "run-p dev:vite",
    "build:vite": "vp build",
    "build": "run-s build:vite",
    "typecheck": "tsc",
    "lint": "vp check",
    "fix": "vp check --fix",
    "test:visual:run": "node scripts/run-visual-test.mjs",
    "test:visual:update:run": "playwright test --update-snapshots",
    "test:visual": "run-s test:visual:run",
    "test:visual:update": "run-s test:visual:update:run",
    "prepare": "vp config"
  },
  "dependencies": {
    "@blueprintjs/core": "6.8.0",
    "@blueprintjs/icons": "6.5.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwindcss": "4.1.18"
  },
  "devDependencies": {
    "@playwright/test": "1.58.2",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^26.1.1",
    "@types/react": "19.2.9",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "autoprefixer": "10.4.24",
    "npm-run-all2": "8.0.4",
    "postcss": "8.5.6",
    "typescript": "5.9.3",
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.15.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": "^24.0.0"
  }
}
